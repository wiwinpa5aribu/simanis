{
  "name": "@simanis/shared",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Shared types, constants, and utilities for SIMANIS",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
