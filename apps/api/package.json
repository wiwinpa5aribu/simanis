{
  "name": "@simanis/api",
  "version": "1.0.0",
  "description": "Backend API untuk SIMANIS - Sistem Manajemen Aset Sekolah",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:cov": "vitest --run --coverage",
    "test:ui": "vitest --ui",
    "test:integration": "vitest --run --config vitest.integration.config.ts"
  },
  "keywords": ["simanis", "asset-management", "school", "fastify", "prisma"],
  "author": "Wiwin Pasaribu <wiwinpa5aribu>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/wiwinpa5aribu/simanis.git"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.937.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.3.0",
    "@fastify/static": "^8.3.0",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.1.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.5.0",
    "@sentry/node": "^10.27.0",
    "@simanis/database": "workspace:*",
    "bullmq": "^5.1.0",
    "exceljs": "^4.4.0",
    "fastify": "^4.25.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.14.0",
    "pino-pretty": "^13.1.2",
    "qrcode": "^1.5.0",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^4.0.15",
    "@vitest/ui": "^4.0.13",
    "fast-check": "^4.3.0",
    "prisma-case-format": "^2.2.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  }
}
