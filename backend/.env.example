# SIMANIS Backend Environment Variables Template
# Copy this file to .env and fill in the actual values

# Application
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Database (Laragon MySQL)
DATABASE_URL="mysql://root:@127.0.0.1:3306/simanis_dev"

# JWT Authentication
JWT_SECRET="your-super-secret-key-change-this-min-32-chars"
JWT_EXPIRES_IN=7d

# Redis (for BullMQ - will be added later)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Cloudflare R2 Storage (Production - optional for now)
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=simanis-assets
R2_PUBLIC_URL=https://your-public-url.com

# CORS (Frontend URL)
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs
