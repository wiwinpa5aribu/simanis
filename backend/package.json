{
  "name": "simanis-backend",
  "version": "1.0.0",
  "description": "Backend API untuk SIMANIS - Sistem Manajemen Aset Sekolah",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest --run"
  },
  "keywords": ["simanis", "asset-management", "school", "fastify", "prisma"],
  "author": "Wiwin Pasaribu <wiwinpa5aribu>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/wiwinpa5aribu/simanis.git"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.937.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^8.1.0",
    "@fastify/static": "^8.3.0",
    "@prisma/client": "5.22.0",
    "argon2": "^0.31.0",
    "bullmq": "^5.1.0",
    "exceljs": "^4.4.0",
    "fastify": "^4.25.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.14.0",
    "prisma": "5.22.0",
    "qrcode": "^1.5.0",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "@vitest/ui": "^4.0.13",
    "eslint": "^9.39.1",
    "fast-check": "^4.3.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.13"
  }
}
